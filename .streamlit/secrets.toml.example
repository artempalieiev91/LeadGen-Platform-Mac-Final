# Скопіюйте у secrets.toml і заповніть значення.
# cp .streamlit/secrets.toml.example .streamlit/secrets.toml

[auth]
username = "your_login"
password = "your_password"

# Опційно: ключ OpenAI (або поле на головній сторінці / Keychain)
# openai_api_key = "sk-..."

# Опційно: Telegram (див. services/telegram_notify.py)
# [telegram]
# bot_token = "..."
# chat_id = "123456789"
